{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar at the bottom of your screen
    "height": 28, // Waybar height
    "reload_style_on_change": true,

    // Order of the modules
    "modules-left": ["hyprland/workspaces"],
    "modules-center": [],
    "modules-right": ["group/hardware", "pulseaudio", "clock"],
    "hyprland/workspaces": {
        "disable-scroll": true,
        "persistent-workspaces": {
            "*": 4
        },
        "all-outputs": false,
        "format": "{icon}",
        "format-icons": {
    		"1": "ЄААБ",
    		"2": "ЄААБ",
    		"3": "ЄААБ",
    		"4": "ЄААБ",
    		"5": "ЄААБ",
    		"6": "ЄААБ",
    		"7": "ЄААБ",
    		"8": "ЄААБ",
    		"9": "ЄААБ",
		    "active": "ЄАзТ"
        },
    },
    "group/hardware": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "children-class": "not-power",
            "transition-left-to-right": false,
        },
        "modules": [
            "battery",
            "temperature",
            "memory",
            "cpu"
        ]
    },
    "temperature": {
       "format": "{icon} {temperatureC}┬░C",
       "format-icons": ["ЄБПГ", "ЄАЗм", "ЄБПД"]
    },
    "memory": {
        "format": "{icon} {0}%",
        "format-icons": ["ЄАзЦ"]
    },
    "cpu": {
       "format": "ЄАле {usage}%"
    },
    "battery": {
       "interval": 60,
       "states": {
           "warning": 30,
           "critical": 15
       },
       "format": "{icon} {capacity}%",
       "format-charging": "ЄАвЛ {capacity}%",
       "format-icons": ["ЄАЫк", "ЄАЫй", "ЄА║╢", "ЄА║╕", "ЄАЫи"],
       "max-length": 25
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon}яКФ {volume}%",
        "format-muted": "ЄАКг 0%",
        "format-icons": {
            "headphones": "яАе",
            "handsfree": "яЦР",
            "headset": "яЦР",
            "default": ["ЄАКе", "ЄАКз", "ЄАКй"]
        },
        "on-click": "pavucontrol"
    },
    "clock": {
        "format": "{:%a %d. %b %I:%M %p}",
        "tooltip-format": "<span size='12pt' font='SF Mono'>{calendar}</span>",
        "calendar": {
            "mode": "month",
            "format": {
                "months": "<span color='#ffffff'>{}</span>",
                "days": "<span color='#ffead3'>{}</span>",
                "weekdays": "<span color='#ffcc66'>{}</span>",
                "today": "<span color='#ff6699'><b>{}</b></span>"
            },
            "actions":  {
                "on-scroll-up": "shift_up",
                "on-scroll-down": "shift_down"
            }
        }
    }
}
